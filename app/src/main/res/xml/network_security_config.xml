<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- By default, disallow cleartext traffic (HTTP) to enforce HTTPS -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
