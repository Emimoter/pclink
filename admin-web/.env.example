# Firebase · Configuración de la app web (Consola → Configuración del proyecto → Tus apps → Web)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
# Obligatorio: crear app "Web" en Firebase y pegar el App ID (formato 1:xxx:web:yyy)
VITE_FIREBASE_APP_ID=
# Opcional (Google Analytics en la misma ficha de la app Web)
VITE_FIREBASE_MEASUREMENT_ID=
